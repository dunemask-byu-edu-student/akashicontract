{
  "name": "akashicontract-api",
  "version": "0.0.2",
  "description": "Realtime, Language Agnostic, Data Schemas & Structures",
  "private": true,
  "scripts": {
    "prebuild": "rm -Rf ${BUILD_PATH:-dist}",
    "build:app": "swc src -d ${BUILD_PATH:-dist} --strip-leading-paths && tsc-alias -p tsconfig.json --dir ${BUILD_PATH:-dist}",
    "start": "NODE_OPTIONS=--enable-source-maps node ${BUILD_PATH:-dist}/main.js",
    "start:dev": "BUILD_PATH=node_modules/.cache/akashicontract NODE_OPTIONS=--enable-source-maps NODE_ENV=dev nodemon --exec 'npm run build:app && npm run start'",
    "tsc": "tsc --noEmit",
    "db:generate": "prisma generate",
    "build": "npm run db:generate && npm run build:app",
    "postinstall": "npm run db:generate"
  },
  "keywords": [
    "AkashiContract"
  ],
  "author": "Dunemask",
  "license": "UNLICENSED",
  "dependencies": {
    "@nestjs/bullmq": "^11.0.4",
    "@nestjs/common": "^11.1.13",
    "@nestjs/config": "^4.0.3",
    "@nestjs/core": "^11.1.13",
    "@nestjs/event-emitter": "^3.0.1",
    "@nestjs/mapped-types": "^2.1.0",
    "@nestjs/platform-express": "^11.1.13",
    "@nestjs/platform-socket.io": "^11.1.13",
    "@nestjs/schedule": "^6.1.1",
    "@nestjs/serve-static": "^5.0.4",
    "@nestjs/websockets": "^11.1.13",
    "@prisma/adapter-pg": "^7.3.0",
    "@prisma/client": "^7.3.0",
    "@socket.io/redis-adapter": "^8.3.0",
    "@socket.io/redis-streams-adapter": "^0.3.0",
    "bcrypt": "^6.0.0",
    "body-parser": "^2.2.2",
    "bullmq": "^5.67.3",
    "chalk": "^5.6.2",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.3",
    "dotenv": "^17.2.4",
    "dotenv-expand": "^12.0.3",
    "express": "^5.2.1",
    "helmet": "^8.1.0",
    "ioredis": "^5.9.2",
    "jsonwebtoken": "^9.0.3",
    "moment-timezone": "^0.6.0",
    "prisma": "^7.3.0",
    "redis": "^5.10.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "socket.io": "^4.8.3",
    "socket.io-adapter": "^2.5.6",
    "socket.io-client": "^4.8.3",
    "yup": "^1.7.1"
  },
  "devDependencies": {
    "@swc/cli": "^0.8.0",
    "@swc/core": "^1.15.11",
    "@types/bcrypt": "^6.0.0",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^25.2.2",
    "nodemon": "^3.1.11",
    "prettier": "^3.8.1",
    "reflect-metadata": "^0.2.2",
    "tsc-alias": "^1.8.16",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  },
  "nodemonConfig": {
    "watch": [
      "src",
      "tsconfig.json",
      "prisma/schema.prisma",
      "package.json",
      ".env"
    ],
    "ext": "ts"
  }
}
