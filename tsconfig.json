{
  "compilerOptions": {
    "strict": true,
    "module": "NodeNext",
    "declaration": true,
    "removeComments": true,
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "allowSyntheticDefaultImports": true,
    "target": "ES2023",
    "sourceMap": true,
    "baseUrl": "./",
    "incremental": true,
    "skipLibCheck": true,
    "strictBindCallApply": false,
    "forceConsistentCasingInFileNames": false,
    "paths":{
      "@atlas/contracts": ["./atlas/contracts/index.ts"],
      "@atlas/scaffold/*": ["./atlas/scaffold/*"],
      "@atlas/enums": ["./atlas/enums/index.ts"],
    }
  },
    "tsc-alias": {
      "resolveFullPaths": true,
      "verbose": false
    }
}