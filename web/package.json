    "@types/react-router-dom": "^5.3.3",
    "lucide-react": "^0.563.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-error-boundary": "^6.1.0",
    "react-hook-form": "^7.71.1",
    "react-router-dom": "^7.13.0",
    "vite-tsconfig-paths": "^6.1.0",
    "yup": "^1.7.1"
  },
  "devDependencies": {
    "@types/node": "^25.3.0",
    "@types/react": "^19.2.13",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.3",
    "globals": "^17.3.0",
    "prettier": "^3.8.1",
    "typescript": "~5.9.3",
    "vite": "^7.3.1"
