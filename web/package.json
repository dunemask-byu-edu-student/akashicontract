{
  "name": "akashicontract-editor",
  "version": "0.0.1-alpha.001",
  "description": "Akashic Contract Editor",
  "author": "Dunemask",
  "private": true,
  "type": "module",
  "scripts": {
    "start:dev": "vite",
    "build": "tsc -b && vite build",
